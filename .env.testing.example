############################################
# Application (Testing)
############################################
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

############################################
# Database (Testing)
# Use Docker db service name when running tests inside containers
############################################
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=nka_hub_testing
DB_USERNAME=root
DB_PASSWORD=

############################################
# Cache / Session / Queue (Testing)
# Use in-memory drivers to keep tests fast + deterministic
############################################
CACHE_DRIVER=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

############################################
# Mail (Testing)
############################################
MAIL_MAILER=array

############################################
# Performance / Testing defaults
############################################
BCRYPT_ROUNDS=4
PASSWORD_TIMEOUT=10800

############################################
# NKA Debug
############################################
NKA_AUTH_DEBUG=false
