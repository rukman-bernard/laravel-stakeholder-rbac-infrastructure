# ---------------------------------------------------------------------------
# MariaDB Custom Configuration
# Applied inside container via:
#   ./my.cnf -> /etc/mysql/conf.d/my.cnf
# ---------------------------------------------------------------------------

[mysqld]

# ---------------------------------------------------------------------------
# Binary Logging
# Disable binlog (not needed for local development / replication disabled)
# ---------------------------------------------------------------------------
skip-log-bin

# ---------------------------------------------------------------------------
# Logging
# Disable general and slow query logs for dev performance
# ---------------------------------------------------------------------------
general_log = 0
slow_query_log = 0

# ---------------------------------------------------------------------------
# InnoDB Memory
# Adjust buffer pool for container environment
# (256M is reasonable for dev setups with limited RAM)
# ---------------------------------------------------------------------------
innodb_buffer_pool_size = 256M