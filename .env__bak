############################################
# Application
############################################
APP_NAME="NKA Academic Management System"
APP_ENV=local
APP_KEY=base64:Xln+bEYHbAA6T2UT+CWefGtcyGDNzd9zKyTa4GGAj5U=
APP_DEBUG=true
APP_URL=http://localhost:8000

############################################
# Logging
############################################
LOG_CHANNEL=stack
LOG_LEVEL=debug

############################################
# Database (Docker: MariaDB)
############################################
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=nka_hub
DB_USERNAME=nka_user
DB_PASSWORD=secret

############################################
# Cache / Session / Queue
############################################
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

############################################
# Redis (Docker)
############################################
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Separate Redis DB indexes
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Cache prefix (applies via config/cache.php)
CACHE_PREFIX=nka_hub_cache_

SESSION_STORE=sessions
SESSION_PREFIX=nka_hub_session_
SESSION_CONNECTION=default


REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90


############################################
# Mail (Local / Safe Defaults)
############################################
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@nka.local"
MAIL_FROM_NAME="${APP_NAME}"

############################################
# Filesystem
############################################
FILESYSTEM_DISK=local

############################################
# Session
############################################
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

############################################
# Broadcasting
############################################
BROADCAST_DRIVER=log

############################################
# Vite / Frontend
############################################
VITE_APP_NAME="${APP_NAME}"

############################################
# Security / Auth
############################################
PASSWORD_TIMEOUT=10800

############################################
# NKA Project Flags
############################################
NKA_AUTH_DEBUG=false
